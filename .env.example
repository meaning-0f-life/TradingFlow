# Database
POSTGRES_USER=tradingflow
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=tradingflow
DATABASE_URL=postgresql+psycopg2://tradingflow:change_this_password@localhost:5432/tradingflow

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (generate a strong secret key)
SECRET_KEY=your-secret-key-change-in-production-make-it-long-and-random-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tradingflow_docs

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-encryption-key-change-in-production

# Celery (Task Queue)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Application
APP_NAME=TradingFlow
APP_URL=http://localhost:3000
DEBUG=false
HOST=0.0.0.0
PORT=8000